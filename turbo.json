{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "VITE_SUPABASE_URL",
    "VITE_SUPABASE_ANON_KEY",
    "VITE_ANTHROPIC_API_KEY",
    "VITE_STRIPE_PRICE_PRO_STARTER_MONTHLY",
    "VITE_STRIPE_PRICE_PRO_STARTER_ANNUAL",
    "VITE_STRIPE_PRICE_PRO_BUILDER_MONTHLY",
    "VITE_STRIPE_PRICE_PRO_BUILDER_ANNUAL",
    "VITE_STRIPE_PRICE_PRO_STUDIO_MONTHLY",
    "VITE_STRIPE_PRICE_PRO_STUDIO_ANNUAL",
    "VITE_STRIPE_PRICE_BUSINESS_MONTHLY",
    "VITE_STRIPE_PRICE_BUSINESS_ANNUAL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    }
  }
}
